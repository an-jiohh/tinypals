{
  "name": "tinypals-desktop-pet",
  "version": "0.1.0",
  "description": "A minimal floating desktop pet with local-first settings and replaceable assets.",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "predev": "node scripts/patch-electron-dev-app.mjs",
    "dev": "electron-vite dev",
    "assets:tinypals": "python3 scripts/build-tinypals-hatch-assets.py",
    "skill:tinypals:install": "python3 scripts/install-tinypals-hatch-pet-skill.py",
    "skill:tinypals:validate": "python3 scripts/validate-tinypals-hatch-pet-skill.py",
    "build": "npm run typecheck && npm run test && electron-vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "release:mac": "npm run build && electron-builder --mac --publish always -c.publish.provider=github",
    "release:win": "npm run build && electron-builder --win --publish always -c.publish.provider=github"
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0",
    "electron-updater": "^6.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "build": {
    "appId": "com.tinypals.desktoppet",
    "productName": "TinyPals",
    "files": [
      "out/**",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
