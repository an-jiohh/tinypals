# Sentry DSN for renderer errors. Fill with the project DSN from Sentry.
VITE_SENTRY_DSN=

# Sentry DSN for Electron main process errors. Usually the same value as VITE_SENTRY_DSN.
SENTRY_DSN=

# Event environment labels shown in Sentry.
VITE_SENTRY_ENVIRONMENT=production
SENTRY_ENVIRONMENT=production

# Source map upload settings. Keep SENTRY_AUTH_TOKEN out of git.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional override. Leave blank to use tinypals-desktop-pet@package-version.
SENTRY_RELEASE=

# Set both to true when you want to force-disable Sentry.
SENTRY_DISABLED=false
VITE_SENTRY_DISABLED=false
